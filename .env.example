# Supabase Database Configuration
# Get these from: https://app.supabase.com/project/_/settings/database

SUPABASE_HOST=your-project.supabase.co
SUPABASE_DATABASE=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=your-super-secret-password
SUPABASE_SSLMODE=require

# Server Configuration
PORT=8080

# NEAR AI Cloud Configuration
# Get API key from: https://cloud.near.ai
NEAR_AI_API_KEY=your-api-key
NEAR_AI_MODEL=deepseek-ai/DeepSeek-V3.1

# Exa AI Research Configuration
# Get API key from: https://dashboard.exa.ai
EXA_API_KEY=a556b0e1-8289-4c86-92c1-24385748b30c

# Optional: Redis URL (if using external Redis instead of Supabase Realtime)
# REDIS_URL=redis://localhost:6379
